<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - exposly.de</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/">exposly.de</a>
            <div class="navbar-nav ms-auto">
                <span class="nav-link text-light">Hallo <%= user.name %></span>
                <a class="nav-link" href="/auth/logout">Logout</a>
            </div>
        </div>
    </nav>

    <div class="container mt-5">
        <h1>Dashboard</h1>
        <p class="lead">Willkommen bei exposly.de!</p>
        
        <div class="row mt-4">
            <div class="col-md-4">
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title">Neues Exposé</h5>
                        <p class="card-text">Erstelle ein professionelles Exposé</p>
                        <a href="/expose/create" class="btn btn-primary">Erstellen</a>
                    </div>
                </div>
            </div>
            
            <div class="col-md-4">
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title">Meine Exposés</h5>
                        <p class="card-text">Verwalte deine erstellten Exposés</p>
                        <a href="/expose/list" class="btn btn-secondary">Anzeigen</a>
                    </div>
                </div>
            </div>
            
            <div class="col-md-4">
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title">Guthaben</h5>
                        <p class="card-text"><%= user.credits || 0 %> Credits</p>
                        <a href="/pricing" class="btn btn-success">Aufladen</a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>